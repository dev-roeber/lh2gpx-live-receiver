# Network binding
BIND_HOST=0.0.0.0
PORT=8080
PUBLIC_HOSTNAME=localhost
PUBLIC_BASE_URL=http://localhost:8080

# Optional client auth; leave empty to disable bearer auth
LIVE_LOCATION_BEARER_TOKEN=

# Optional operator UI auth. If unset, the dashboard is local-only.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Local storage
DATA_DIR=/app/data
SQLITE_PATH=/app/data/receiver.sqlite3
RAW_PAYLOAD_NDJSON_PATH=/app/data/raw-payloads.ndjson
LEGACY_REQUEST_NDJSON_PATH=/app/data/live-location.ndjson
# Raw-payload log: stores full GPS payloads per request in NDJSON format.
# File is created with mode 0600 (owner-read/write only).
# Set to false to disable; true retains debugging capability.
ENABLE_RAW_PAYLOAD_NDJSON=true
LOCAL_TIMEZONE=UTC

# Python/FastAPI logging
LOG_LEVEL=INFO
REQUEST_BODY_MAX_BYTES=262144
POINTS_PAGE_SIZE_DEFAULT=50
POINTS_PAGE_SIZE_MAX=250
RATE_LIMIT_REQUESTS_PER_MINUTE=0
TRUST_PROXY_HEADERS=true
LOGS_DIR=/app/logs
