{
	admin off
}

{$PUBLIC_HOSTNAME:localhost} {
	encode zstd gzip

	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		Permissions-Policy "interest-cohort=()"
		-Server
	}

	log {
		output stdout
		format json
	}

	reverse_proxy live-location-receiver:8080
}
